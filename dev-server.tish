// Dev server for Tish playground. Serves public/ statically.
// Run: tish run dev-server.tish --feature http,fs,process
// Uses readFile+body for text (like http-hello); file: only for .wasm (binary).
import { fileExists, readFile, isDir } from "fs"
import { process } from "process"
import { serve } from "http"

const PUBLIC = "public"

fn contentType(path) {
  if (path.endsWith(".html")) { return "text/html; charset=utf-8" }
  if (path.endsWith(".css")) { return "text/css; charset=utf-8" }
  if (path.endsWith(".js")) { return "application/javascript; charset=utf-8" }
  if (path.endsWith(".wasm")) { return "application/wasm" }
  if (path.endsWith(".json")) { return "application/json" }
  return "application/octet-stream"
}

fn isBinary(path) {
  path.endsWith(".wasm")
}

fn filePath(reqPath) {
  if (reqPath === "/" || reqPath === "") { return PUBLIC + "/index.html" }
  let p = reqPath.startsWith("/") ? reqPath.slice(1) : reqPath
  return PUBLIC + "/" + p
}

fn isDirectory(path) {
  return isDir(path)
}

fn handleRequest(req) {
  let path = filePath(req.path)
  if (!fileExists(path)) { return { status: 404, body: "Not found: " + req.path } }
  // Binary files (e.g. .wasm) must use file: streaming — never readFile (would fail on UTF-8)
  if (isBinary(path)) {
    if (isDirectory(path)) {
      let idx = path + "/index.html"
      if (fileExists(idx)) {
        let body = readFile(idx)
        if (body && typeof body === "object" && body.error) { return { status: 500, body: "Error: " + body.error } }
        return { status: 200, headers: { "Content-Type": "text/html; charset=utf-8" }, body }
      }
      return { status: 403, body: "Directory listing disabled" }
    }
    return { status: 200, headers: { "Content-Type": contentType(path) }, file: path }
  }
  if (isDirectory(path)) {
    path = path + "/index.html"
    if (!fileExists(path)) { return { status: 403, body: "Directory listing disabled" } }
  }
  let headers = { "Content-Type": contentType(path) }
  let body = readFile(path)
  if (body && typeof body === "object" && body.error) {
    return { status: 500, body: "Error: " + body.error }
  }
  return { status: 200, headers, body }
}

let port = "PORT" in process.env ? parseInt(process.env.PORT) : 8765
console.log("Tish playground at http://127.0.0.1:" + port)
serve(port, handleRequest)
